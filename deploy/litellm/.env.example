# LiteLLM proxy 容器的上游凭据（standalone 用）。
# cp .env.example .env 后填值。本文件只被 deploy/docker-compose.standalone.yml 的
# litellm 服务通过 env_file 读取，不与项目根 .env 混用（上游 secret 与业务配置分离）。

# proxy 自身的 master key。★ 必须与项目根 .env 的 LITELLM_API_KEY 完全一致 ★
# 生成：openssl rand -hex 24，前面建议带 sk- 前缀（litellm 习惯）。
LITELLM_MASTER_KEY=sk-CHANGEME

# ---- 栈 A：国产栈（config.yaml 默认启用）----
# 小米 MiMo 开放平台的 OpenAI 兼容 endpoint 与 key（从小米开放平台获取，去掉末尾 /chat/completions）
MIMO_API_BASE=
MIMO_API_KEY=
# Voyage（embedding + rerank）；200M tokens 免费额度
VOYAGE_API_KEY=

# ---- 栈 B：OpenAI 栈（启用 config.yaml 里 OpenAI 段时填）----
OPENAI_API_KEY=
